# Site (Vercel production URL — update after deploy)
NEXT_PUBLIC_SITE_URL=https://angle-app-jet.vercel.app

# Dev from phone: run `npm run dev` and open the printed LAN IP (not 0.0.0.0).
# PC and phone must be on the same Wi-Fi. If blocked, allow Node.js in Windows Firewall.

# Supabase — same project as DotMap (bnjvnkjksuojqhtjflvh)
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://bnjvnkjksuojqhtjflvh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OAuth redirect URLs (Supabase → Authentication → URL Configuration):
# http://localhost:3000/auth/callback
# http://127.0.0.1:3000/auth/callback
# https://angle-app-jet.vercel.app/auth/callback
# Or wildcard: https://angle-app-jet.vercel.app/**

# Server-only (Vercel env, never commit)
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated, no quotes: dimaa9489@gmail.com,other@gmail.com
ADMIN_EMAILS=your@email.com

# Admin panel: https://angle-app-jet.vercel.app/admin
# Requires ADMIN_EMAILS + SUPABASE_SERVICE_ROLE_KEY + R2 vars on Vercel

# Cloudflare R2 (admin upload on Vercel)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
# Same URL as R2_PUBLIC_URL — needed in browser to show photos when image_url in DB is wrong
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Multilingual search — DeepL translates pose titles into keywords on publish (server-only).
# Free key ends with :fx — https://www.deepl.com/pro-api
DEEPL_API_KEY=
# Optional fallback if DeepL is not set:
# LIBRETRANSLATE_URL=https://libretranslate.com
# LIBRETRANSLATE_API_KEY=
